{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tau",
  "version": "0.3.0",
  "identifier": "com.gzjggg.tau",
  "build": {
    "frontendDist": "../../../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tau",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "gzjggg",
    "copyright": "Copyright © 2026 gzjggg / Tau contributors",
    "category": "DeveloperTool",
    "shortDescription": "Desktop shell for Tau — Pi session mirror UI",
    "longDescription": "Tau Desktop is a native Windows window for the Tau web UI. It bundles the same public UI and connects to your Pi/Tau extension on 127.0.0.1. Closing the window does not exit Pi.",
    "homepage": "https://github.com/gzjggg/tau",
    "resources": [
      "icons/icon-light.png",
      "icons/icon-dark.png",
      "icons/icon-light.ico",
      "icons/icon-dark.ico"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": false,
        "startMenuFolder": "Tau"
      }
    }
  }
}
